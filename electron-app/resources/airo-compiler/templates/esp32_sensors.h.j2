{% if hcsr04_pins | length > 0 %}
// HC-SR04 ultrasonic sensor support
{% for pin in hcsr04_pins %}
float read_ultrasonic_cm_{{ pin.name }}() {
    // HC-SR04 on GPIO{{ pin.number }}
    long duration = pulseIn(PIN_{{ pin.name_upper }}, HIGH);
    return duration * 0.034 / 2.0;
}
{% endfor %}
{% endif %}

