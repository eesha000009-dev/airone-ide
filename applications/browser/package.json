{
  "private": true,
  "name": "airone-ide-browser-app",
  "description": "Airone IDE - Robotics Programming Environment (Browser)",
  "productName": "Airone IDE",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Airone",
  "homepage": "https://github.com/eesha000009-dev/airone-ide#readme",
  "bugs": {
    "url": "https://github.com/eesha000009-dev/airone-ide/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eesha000009-dev/airone-ide.git"
  },
  "engines": {
    "yarn": ">=1.7.0 <2",
    "node": ">=22"
  },
  "theia": {
    "frontend": {
      "config": {
        "applicationName": "Airone IDE",
        "warnOnPotentiallyInsecureHostPattern": false,
        "preferences": {
          "files.enableTrash": false,
          "security.workspace.trust.enabled": false
        },
        "reloadOnReconnect": true
      }
    },
    "backend": {
      "config": {
        "warnOnPotentiallyInsecureHostPattern": false,
        "startupTimeout": -1,
        "resolveSystemPlugins": false,
        "configurationFolder": ".airone-ide",
        "frontendConnectionTimeout": 3000
      }
    },
    "generator": {
      "config": {
        "preloadTemplate": "./resources/preload.html"
      }
    }
  },
  "dependencies": {
    "@theia/bulk-edit": "1.72.0-next.42",
    "@theia/callhierarchy": "1.72.0-next.42",
    "@theia/collaboration": "1.72.0-next.42",
    "@theia/console": "1.72.0-next.42",
    "@theia/core": "1.72.0-next.42",
    "@theia/debug": "1.72.0-next.42",
    "@theia/dev-container": "1.72.0-next.42",
    "@theia/editor": "1.72.0-next.42",
    "@theia/editor-preview": "1.72.0-next.42",
    "@theia/external-terminal": "1.72.0-next.42",
    "@theia/file-search": "1.72.0-next.42",
    "@theia/filesystem": "1.72.0-next.42",
    "@theia/getting-started": "1.72.0-next.42",
    "@theia/keymaps": "1.72.0-next.42",
    "@theia/markers": "1.72.0-next.42",
    "@theia/memory-inspector": "1.72.0-next.42",
    "@theia/messages": "1.72.0-next.42",
    "@theia/metrics": "1.72.0-next.42",
    "@theia/mini-browser": "1.72.0-next.42",
    "@theia/monaco": "1.72.0-next.42",
    "@theia/navigator": "1.72.0-next.42",
    "@theia/notebook": "1.72.0-next.42",
    "@theia/outline-view": "1.72.0-next.42",
    "@theia/output": "1.72.0-next.42",
    "@theia/plugin-ext": "1.72.0-next.42",
    "@theia/plugin-ext-vscode": "1.72.0-next.42",
    "@theia/preferences": "1.72.0-next.42",
    "@theia/preview": "1.72.0-next.42",
    "@theia/process": "1.72.0-next.42",
    "@theia/property-view": "1.72.0-next.42",
    "@theia/remote": "1.72.0-next.42",
    "@theia/scanoss": "1.72.0-next.42",
    "@theia/scm": "1.72.0-next.42",
    "@theia/search-in-workspace": "1.72.0-next.42",
    "@theia/secondary-window": "1.72.0-next.42",
    "@theia/task": "1.72.0-next.42",
    "@theia/terminal": "1.72.0-next.42",
    "@theia/terminal-manager": "1.72.0-next.42",
    "@theia/test": "1.72.0-next.42",
    "@theia/timeline": "1.72.0-next.42",
    "@theia/typehierarchy": "1.72.0-next.42",
    "@theia/userstorage": "1.72.0-next.42",
    "@theia/variable-resolver": "1.72.0-next.42",
    "@theia/vsx-registry": "1.72.0-next.42",
    "@theia/workspace": "1.72.0-next.42",
    "fs-extra": "^9.1.0",
    "airone-ide-product-ext": "0.1.0",
    "airone-ide-airo-ext": "0.1.0"
  },
  "devDependencies": {
    "@theia/cli": "1.72.0-next.42",
    "@theia/bundle-plugin": "1.72.0-next.42"
  },
  "scripts": {
    "clean": "theia clean && rimraf node_modules",
    "build": "yarn -s rebuild && theia build --app-target=\"browser\" --mode development",
    "build:prod": "yarn -s rebuild && theia  build --app-target=\"browser\"",
    "rebuild": "theia rebuild:browser --cacheRoot ../..",
    "start": "theia start --plugins=local-dir:../../plugins",
    "watch": "concurrently --kill-others -n tsc,build -c red,yellow \"tsc -b -w --preserveWatchOutput\" \"yarn -s watch:bundle\"",
    "update:theia": "ts-node ../../scripts/update-theia-version.ts",
    "update:next": "ts-node ../../scripts/update-theia-version.ts next"
  }
}
