{
  "private": true,
  "name": "airone-ide-electron-app",
  "description": "Airone IDE - Robotics Programming Environment",
  "productName": "Airone IDE",
  "version": "0.1.0",
  "main": "scripts/theia-electron-main.js",
  "license": "MIT",
  "author": {
    "name": "Airone",
    "email": "airone@eesha000009.dev"
  },
  "homepage": "https://github.com/eesha000009-dev/airone-ide#readme",
  "bugs": {
    "url": "https://github.com/eesha000009-dev/airone-ide/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eesha000009-dev/airone-ide.git"
  },
  "engines": {
    "yarn": ">=1.7.0 <2",
    "node": ">=22"
  },
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "Airone IDE",
        "reloadOnReconnect": true,
        "preferences": {
          "window.menuBarVisibility": "visible",
          "toolbar.showToolbar": false,
          "files.exclude": {
            "**/.airone-ide": true,
            "**/.theia": true,
            "**/build": true,
            "**/theia-workspace": true
          },
          "editor.showTabs": "single",
          "workbench.editor.showTabs": "single",
          "workbench.editor.highlightModifiedTabs": false,
          "explorer.autoReveal": true,
          "files.autoSave": "afterDelay"
        },
        "electron": {
          "showWindowEarly": false,
          "windowOptions": {
            "backgroundColor": "#ffffff"
          },
          "splashScreenOptions": {
            "content": "resources/AironeIDESplash.svg",
            "height": 400,
            "width": 600
          }
        }
      }
    },
    "backend": {
      "config": {
        "frontendConnectionTimeout": -1,
        "startupTimeout": -1,
        "resolveSystemPlugins": false,
        "configurationFolder": ".airone-ide"
      }
    },
    "generator": {
      "config": {
        "preloadTemplate": "./resources/preload.html"
      }
    }
  },
  "dependencies": {
    "@theia/core": "1.72.0-next.42",
    "@theia/editor": "1.72.0-next.42",
    "@theia/electron": "1.72.0-next.42",
    "@theia/file-search": "1.72.0-next.42",
    "@theia/filesystem": "1.72.0-next.42",
    "@theia/getting-started": "1.72.0-next.42",
    "@theia/markers": "1.72.0-next.42",
    "@theia/messages": "1.72.0-next.42",
    "@theia/monaco": "1.72.0-next.42",
    "@theia/navigator": "1.72.0-next.42",
    "@theia/output": "1.72.0-next.42",
    "@theia/plugin-ext": "1.72.0-next.42",
    "@theia/plugin-ext-vscode": "1.72.0-next.42",
    "@theia/preferences": "1.72.0-next.42",
    "@theia/process": "1.72.0-next.42",
    "@theia/scm": "1.72.0-next.42",
    "@theia/terminal": "1.72.0-next.42",
    "@theia/userstorage": "1.72.0-next.42",
    "@theia/variable-resolver": "1.72.0-next.42",
    "@theia/vsx-registry": "1.72.0-next.42",
    "@theia/workspace": "1.72.0-next.42",
    "fs-extra": "^9.1.0",
    "airone-ide-launcher-ext": "0.1.0",
    "airone-ide-product-ext": "0.1.0",
    "airone-ide-updater-ext": "0.1.0",
    "airone-ide-airo-ext": "0.1.0"
  },
  "devDependencies": {
    "@theia/cli": "1.72.0-next.42",
    "@theia/bundle-plugin": "1.72.0-next.42",
    "@types/js-yaml": "^3.12.10",
    "@types/yargs": "^17",
    "app-builder-lib": "26.0.12",
    "chai": "^4.5.0",
    "concurrently": "^3.6.1",
    "electron": "39.8.7",
    "electron-builder": "26.0.12",
    "electron-mocha": "^12.3.1",
    "electron-osx-sign": "^0.6.0",
    "js-yaml": "^3.14.2",
    "mocha": "^8.4.0",
    "rimraf": "^2.7.1",
    "ts-node": "^10.9.2",
    "yargs": "^17.7.2"
  },
  "scripts": {
    "clean": "theia clean && rimraf node_modules",
    "clean:dist": "rimraf dist",
    "build": "yarn -s rebuild && theia build --app-target=\"electron\" --mode development",
    "build:prod": "yarn -s rebuild && theia build --app-target=\"electron\"",
    "rebuild": "theia rebuild:electron --cacheRoot ../..",
    "watch": "concurrently -n compile,build \"theiaext watch --preserveWatchOutput\" \"theia build --watch --mode development\"",
    "start": "electron scripts/theia-electron-main.js --plugins=local-dir:../../plugins",
    "start:debug": "yarn start --log-level=debug",
    "package": "yarn clean:dist && yarn rebuild && electron-builder -c.mac.identity=null --publish never",
    "package:prod": "yarn deploy",
    "deploy": "yarn clean:dist && yarn rebuild && electron-builder -c.mac.identity=null --publish never",
    "package:preview": "yarn clean:dist && yarn rebuild && electron-builder -c.mac.identity=null --dir",
    "update:checksum": "ts-node scripts/update-checksum.ts",
    "update:blockmap": "ts-node scripts/update-blockmap.ts",
    "update:theia": "ts-node ../../scripts/update-theia-version.ts",
    "update:next": "ts-node ../../scripts/update-theia-version.ts next",
    "sign:directory": "ts-node scripts/sign-directory.ts",
    "sign:directory:windows": "ts-node scripts/sign-directory-windows.ts",
    "test": "mocha --timeout 60000 \"./test/*.spec.js\"",
    "lint": "eslint --ext js,jsx,ts,tsx scripts && eslint --ext js,jsx,ts,tsx test",
    "lint:fix": "eslint --ext js,jsx,ts,tsx scripts --fix && eslint --ext js,jsx,ts,tsx test -fix"
  }
}