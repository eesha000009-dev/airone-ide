using namespace websockets;

// === MAIN SETUP ===
void setup() {
    Serial.begin(115200);
    delay(1000);
    Serial.println("========================================");
    Serial.println("  Airone Robot Starting...");
    Serial.println("  Robot: {{ robot_name }}");
    Serial.println("  Brain: {{ brain_url }}");
    Serial.println("========================================");

    // Initialize pins
{% for pin in pin_defs %}
{% if pin.mode == "output" %}
    pinMode(PIN_{{ pin.name_upper }}, OUTPUT);
    servo_{{ pin.name }}.attach(PIN_{{ pin.name_upper }});
{% else %}
    pinMode(PIN_{{ pin.name_upper }}, INPUT);
{% endif %}
{% endfor %}

{% set dht_pins = pin_defs | selectattr('sensor_type', 'equalto', 'DHT22') | list %}
{% if dht_pins | length > 0 %}
    // Initialize DHT sensors
{% for pin in dht_pins %}
    dht_{{ pin.name }}.begin();
{% endfor %}
{% endif %}

    // Connect WiFi
    connect_wifi();

    // Connect to brain
    connect_brain();

    Serial.println("[SETUP] Complete. Entering main loop...");
}

// === MAIN LOOP (SENSE → THINK → ACT → SAFETY) ===
void loop() {
    // Poll WebSocket (must be called regularly)
    brain_client.poll();

    // Phase 1: SENSE (read_for)
    read_all_sensors();

{% if senddatato %}
    // Phase 2: THINK (senddatato - sends natural language prompt to brain)
    if (brain_connected) {
        send_sensor_data();
    } else {
        // Attempt reconnection with backoff
        attempt_reconnection();
    }
{% else %}
    // No senddatato configured - skipping THINK phase
{% endif %}

    // Phase 3: ACT (actfor - execute brain commands)
    // The brain responds to our natural language prompt with a JSON command.
    // The AI reads "Currently, the input sensors read: (...), What do you want to do to: (...)"
    // and responds with: {"output_commands": {"module_name": {"action": "...", "value": ...}}}
    if (new_command_ready) {
        // Try to parse as JSON command from brain
        StaticJsonDocument<1024> cmd_doc;
        DeserializationError err = deserializeJson(cmd_doc, pending_command);
        if (!err) {
{% if has_ask %}
            // Check for ask() response
            if (cmd_doc.containsKey("ask_response")) {
                const char* answer = cmd_doc["ask_response"];
                Serial.print("[ASK] Brain says: ");
                Serial.println(answer);
            }
{% endif %}

            if (cmd_doc.containsKey("output_commands")) {
                JsonObject commands = cmd_doc["output_commands"];
                for (JsonPair kv : commands) {
                    const char* module = kv.key().c_str();
                    JsonObject cmd = kv.value();
                    execute_brain_command(module, cmd);
                }
            }
        } else {
            // Not JSON - could be a direct text response from the brain
            Serial.print("[BRAIN] Text response: ");
            Serial.println(pending_command);
        }
        new_command_ready = false;
    }

    // Phase 4: SAFETY (always runs, highest priority)
    run_safety_checks();

    // Loop interval
    delay({{ read_duration }});
}

