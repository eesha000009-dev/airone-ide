{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Airone",
  "scopeName": "source.airo",
  "fileTypes": [".airo"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#modes"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.airo",
          "match": "##.*##"
        },
        {
          "name": "comment.line.number-sign.airo",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.airo",
          "match": "\b(pin|defi|call|loop|read|read_for|senddatato|actfor|ask|init|if|else)\b"
        }
      ]
    },
    "modes": {
      "patterns": [
        {
          "name": "storage.modifier.airo",
          "match": "\b(input|output)\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.airo",
      "begin": """,
      "end": """,
      "patterns": [
        {
          "name": "constant.character.escape.airo",
          "match": "\\."
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.airo",
      "match": "\b\d+(?:\.\d+)?\b"
    },
    "identifiers": {
      "name": "variable.other.airo",
      "match": "[a-zA-Z_][a-zA-Z0-9_-]*"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.airo",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.airo",
          "match": "<|>|==|!="
        },
        {
          "name": "punctuation.terminator.airo",
          "match": "\."
        },
        {
          "name": "punctuation.delimiter.airo",
          "match": ";"
        }
      ]
    }
  }
}
