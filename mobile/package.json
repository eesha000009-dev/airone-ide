{
  "name": "airone-ide-mobile",
  "version": "0.1.0",
  "description": "Airone IDE - Mobile Android Build",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cap:sync": "cap sync",
    "cap:add:android": "cap add android",
    "cap:open:android": "cap open android",
    "android:build:release": "cap sync && cd android && ./gradlew assembleRelease",
    "android:build:debug": "cap sync && cd android && ./gradlew assembleDebug",
    "generate-keystore": "bash scripts/generate-keystore.sh"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "monaco-editor": "^0.50.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "terser": "^5.36.0"
  }
}
